<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Settings - TempoTalk</title>

    <!-- Styles -->
    <link rel="stylesheet" href="/css/settings.css">
    <link rel="stylesheet" href="/css/general.css">
</head>
<body>
    <div class="crop-logo">
        <a href="/">
            <img src="/images/tempotalk_logo.png" alt="tempotalk logo" id="logo">
        </a>
    </div>

    <main class="settings-card">
    <h2>Account Settings</h2>
    
    <form action="/update-settings" method="POST">
        <div class="input-group">
            <label for="username">Name</label>
            <input type="text" id="username" name="username" placeholder="User" onfocus="this.select()">
        </div>

        <div class="input-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Email" onfocus="this.select()">
        </div>

        <div class="input-group">
            <label for="password">New Password</label>
            <input type="password" id="password" name="password" placeholder="Password">
        </div>

        <button type="submit" class="btn-update">Save Changes</button>
    </form>

    <div class="danger-zone" style="margin-top: 25px; text-align: center; border-top: 1px solid #444; padding-top: 15px;">
        <form action="/delete-account" method="POST" onsubmit="return confirm('Delete account permanently?')">
            <button type="submit" class="delete-link" style="background: none; border: none; color: #777; text-decoration: underline; cursor: pointer; font-size: 0.8rem;">
                Delete Account
            </button>
        </form>
    </div>
    </main>
    <div class="column">
            <div>
                <a href="/create-account">Log In</a>
                <a href="/create-account">/ Create Account</a>
                <a href="/settings">/ Account Settings</a>
            </div>
    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>
    
    <!-- Styles -->
    <link rel="stylesheet" href="/css/create.css">
    <link rel="stylesheet" href="/css/general.css">

    <!-- Scripts -->
    <script src="/js/tempo.js" defer></script>
</head>
<body>
    <!-- Navigation Bar -->
    <%- include('partials/nav-new') %>

    <!-- content -->
    <form id="account-creation" action="/in-account" method="POST">
        <h2>Create an Account</h2>
        <br>
        <label for="username">Username:
            <span class="err" id="err-username">
                *username is required*
            </span>
        </label>
        <input type="text" id="username" name="username">
        <br>
        <label for="password">Password:
            <span class="err" id="err-password">
                *password is required*
            </span>
        </label>
        <input type="password" id="password" name="password">
        <br>
        <label for="confirm">Confirm Password:
            <span class="err" id="err-confirm">
                *password is not the same*
            </span>
        </label>
        <input type="password" id="confirm" name="confirm">
        <br>
        <label for="email">Email:
            <span class="err" id="err-email">
                *email is required*
            </span>
        </label>
        <input type="text" id="email" name="email">
        <br>
        <button type="submit">Create Account</button>
        <br>
        <a href="/login" id="no-account">Already have an account? Click here</a>
    </form>

</body>
</html>
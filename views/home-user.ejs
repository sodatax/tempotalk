<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TempoTalk</title>

    <!-- Styles -->
    <link rel="stylesheet" href="/css/general.css">
    <link rel="stylesheet" href="/css/home.css">

</head>
<body>
    <!-- Navigation Bar -->
    <nav>
        <a href="/home-user" class="crop-logo">
            <img src="/images/tempotalk_logo_white.png" alt="tempotalk logo" id="logo">
        </a>
        <div id="nav-right">
            <a href="/home-user"><strong><%= userInfo.username %></strong></a>
            <a href="/settings"><strong>Settings</strong></a>
        </div>
    </nav>
    
    <div class="layout-container">
        <div class="column" id="column-left">

        </div>

        <div class="column" id="column-middle">
            <h1>Welcome to TempoTalk!</h1>
            <h1>Where fellow music artists can share anything music-related in blog posts</h1>
            <h1>Have fun!</h1>
            <p>Content</p>
        </div>

        <div class="column" id="column-right">
            <a href="/settings">Account Settings</a>
            <a href="/" class="bottom-right">Log Out</a>
        </div>
    </div>
</body>
</html>
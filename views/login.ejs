<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log-in with us</title>

    <!-- Styles -->
    <link rel="stylesheet" href="/css/account-input.css">
    <link rel="stylesheet" href="/css/general.css">
    <link rel="icon" type="image/png" href="/images/tempotalk_logo_white.png">

    <!-- Scripts -->
    <script src="js/login.js" defer></script>
    
</head>
<body>
    <!-- Navigation Bar -->
    <%- include('partials/nav-new') %>

    <!-- content -->
    <form id="account-creation" action="/login" method="POST">

        <% if (typeof errors != 'undefined') { %>
            <% errors.forEach(error => { %>
                <p><%= error %></p>
            <% }); %>
        <% } %>

        <h2>Log in to your account</h2>
        <br>
        <% if (locals.error) { %>
            <p class="auth-error">
                <%= error %>
            </p>
        <% } %>
        <label for="username">Username:
            <span class="err" id="err-username">
                *username is required*
            </span>
        </label>
        <input type="text" id="username" name="username">
        <br>
        <label for="password">Password:
            <span class="err" id="err-password">
                *password is required*
            </span>
        </label>
        <input type="password" id="password" name="password">
        <br>
        <button type="submit">Log In</button>
        <br>
        <a href="/create-account" id="no-account">Don't have an account? Click here</a>
    </form>
</body>
</html>
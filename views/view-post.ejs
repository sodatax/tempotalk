<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TempoTalk</title>

    <!-- Styles -->
    <link rel="stylesheet" href="/css/general.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="icon" type="image/png" href="/images/tempotalk_logo_white.png">

</head>
<body>
    <!-- Navigation Bar -->
    <%- include('partials/nav-new') %>

    <!-- NOTE: MAKE NAV IF STATEMENT FOR NAV BAR > if(user) then nav-user, else nav-new -->

    <div class="layout-container">
        <div class="column" id="column-left">
            <a href="/home-user/<%= userInfo.username %>">< Back</a>
        </div>

    <div class="column" id="column-middle">
        <h1><%= post.title %></h1>
        <p>
            Posted by <strong><%= post.username %></strong>
            • <%= new Date(post.created_at).toLocaleString() %>
        </p>
        <p><%= post.content %></p>
        <% if (post.links) { %>
            <p>
                Link:
                <a href="<%= post.links %>" target="_blank">
                    <%= post.links %>
                </a>
            </p>
        <% } %>
    </div>

        <div class="column" id="column-right">
            <div>

            </div>
        </div>
    </div>
</body>
</html>